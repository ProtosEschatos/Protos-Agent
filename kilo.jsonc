    "telegram_send_message": "allow",
    "telegram_get_updates": "allow",
    "telegram_get_bot_info": "allow",
    "telegram_poll_messages": "allow",
    "playwright_playwright_navigate": "allow",
    "playwright_playwright_get": "allow",
    "playwright_start_codegen_session": "allow",
    "playwright_end_codegen_session": "allow",
    "playwright_get_codegen_session": "allow",
    "playwright_clear_codegen_session": "allow",
    "playwright_playwright_screenshot": "allow",
    "playwright_playwright_click": "allow",
    "playwright_playwright_iframe_click": "allow",
    "playwright_playwright_iframe_fill": "allow",
    "playwright_playwright_fill": "allow",
    "playwright_playwright_select": "allow",
    "playwright_playwright_hover": "allow",
    "playwright_playwright_upload_file": "allow",
    "playwright_playwright_evaluate": "allow",
    "playwright_playwright_console_logs": "allow",
    "playwright_playwright_resize": "allow",
    "playwright_playwright_close": "allow",
    "playwright_playwright_post": "allow",
    "playwright_playwright_put": "allow",
    "playwright_playwright_patch": "allow",
    "playwright_playwright_delete": "allow",
    "playwright_playwright_expect_response": "allow",
    "playwright_playwright_assert_response": "allow",
    "playwright_playwright_custom_user_agent": "allow",
    "playwright_playwright_get_visible_text": "allow",
    "playwright_playwright_get_visible_html": "allow",
    "playwright_playwright_go_back": "allow",
    "playwright_playwright_go_forward": "allow",
    "playwright_playwright_drag": "allow",
    "playwright_playwright_press_key": "allow",
    "playwright_playwright_save_as_pdf": "allow",
    "playwright_playwright_click_and_switch_tab": "allow",
