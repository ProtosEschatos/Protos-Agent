    "firecrawl_scrape": "allow",
    "firecrawl_crawl": "allow",
    "firecrawl_check_crawl_status": "allow",
    "firecrawl_map": "allow",
    "firecrawl_search": "allow",
    "firecrawl_search_feedback": "allow",
    "firecrawl_extract": "allow",
    "firecrawl_parse": "allow",
    "firecrawl_interact": "allow",
    "firecrawl_interact_stop": "allow",
    "firecrawl_agent": "allow",
    "firecrawl_agent_status": "allow",
    "firecrawl_monitor_create": "allow",
    "firecrawl_monitor_list": "allow",
    "firecrawl_monitor_get": "allow",
    "firecrawl_monitor_update": "allow",
    "firecrawl_monitor_delete": "allow",
    "firecrawl_monitor_run": "allow",
    "firecrawl_monitor_checks": "allow",
    "firecrawl_monitor_check": "allow"
