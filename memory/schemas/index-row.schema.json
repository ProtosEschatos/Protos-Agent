{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Protos-Agent memory index row",
  "description": "One line of memory/index.jsonl.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "date", "project", "session", "commits", "topics", "title"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-\\d{2}$",
      "description": "YYYY-MM-DD-NN (2-digit sequence within the day)"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "project": {
      "type": "string",
      "minLength": 1
    },
    "session": {
      "type": "string",
      "pattern": "^memory/sessions/\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]+\\.md$"
    },
    "project_doc": {
      "type": "string",
      "pattern": "^memory/projects/[a-z0-9-]+\\.md$"
    },
    "learnings": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^memory/learnings/[a-z0-9-]+\\.md$"
      }
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-f]{7,40}$"
      }
    },
    "topics": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
    },
    "title": {
      "type": "string",
      "minLength": 1
    }
  }
}
